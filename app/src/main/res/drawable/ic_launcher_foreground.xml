<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground (108dp canvas).
    The safe zone is the inner 72dp (18dp inset on every side).
    The logo is inset a further 8dp so it never clips on any mask shape.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:top="26dp"
        android:bottom="26dp"
        android:left="26dp"
        android:right="26dp">
        <bitmap
            android:src="@drawable/medibloom_logo"
            android:gravity="center"
            android:tileMode="disabled" />
    </item>
</layer-list>
